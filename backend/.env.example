# ─── Backend Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# The start scripts load .env automatically via python-dotenv.

# ── AI Coding Agent (required to enable live AI responses) ────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Server tuning (optional — defaults shown) ─────────────────────
PORT=5000
WEB_CONCURRENCY=2   # Gunicorn worker processes (Mac/Linux)
THREADS=4           # Waitress threads (Windows)
